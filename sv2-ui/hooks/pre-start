#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(readlink -f "$(dirname "${BASH_SOURCE[0]}")/..")"
APP_DATA_DIR="${APP_DIR}/data"

DOCKER_DIR="${APP_DATA_DIR}/docker"
ENTRYPOINT_FILE="${APP_DIR}/entrypoint.sh"

insert_entrypoint_firewall_patch() {
    local entrypoint_file="${1}"
    local patch_file
    local tmp_file

    if [[ ! -f "${entrypoint_file}" ]] || grep -q "configure_bridge_forwarding" "${entrypoint_file}"
    then
        return
    fi

    patch_file="$(mktemp)"
    tmp_file="$(mktemp)"

    cat > "${patch_file}" <<'PATCH'
configure_bridge_forwarding() {
    local bridge="${1}"
    local subnet="${2}"

    # dockerd runs with --iptables=false so the nested Docker daemon cannot
    # rewrite Umbrel's host Docker chains. Add only the scoped forwarding/NAT
    # rules needed by sv2-ui's nested Translator/JDC containers.
    iptables -C FORWARD -i "${bridge}" -j ACCEPT 2>/dev/null || iptables -A FORWARD -i "${bridge}" -j ACCEPT
    iptables -C FORWARD -o "${bridge}" -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || iptables -A FORWARD -o "${bridge}" -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
    iptables -t nat -C POSTROUTING -s "${subnet}" ! -o "${bridge}" -j MASQUERADE 2>/dev/null || iptables -t nat -A POSTROUTING -s "${subnet}" ! -o "${bridge}" -j MASQUERADE
}
PATCH

    awk -v patch_file="${patch_file}" '
        /^DOCKER_SOCKET="/ && inserted == 0 {
            while ((getline line < patch_file) > 0) {
                print line
            }
            close(patch_file)
            print ""
            inserted = 1
        }
        /ensure_bridge_exists "\$\{bridge\}" "\$\{ip_range\}"/ && called == 0 {
            print
            print "    configure_bridge_forwarding \"${bridge}\" \"${ip_range}\""
            called = 1
            next
        }
        { print }
    ' "${entrypoint_file}" > "${tmp_file}"

    cat "${tmp_file}" > "${entrypoint_file}"
    rm -f "${patch_file}" "${tmp_file}"
}

# entrypoint.sh is mounted from app data but is not copied into existing installs
# during app updates, so migrate the v0.1.0 timeout in place.
if [[ -f "${ENTRYPOINT_FILE}" ]] && grep -q 'for i in $(seq 1 30); do' "${ENTRYPOINT_FILE}"
then
    sed -i.bak \
        -e '/CONFIG_SOURCE_PATH="\/app\/data\/config"/a\
DOCKER_READY_TIMEOUT_SECONDS=180' \
        -e 's/for i in $(seq 1 30); do/for i in $(seq 1 "${DOCKER_READY_TIMEOUT_SECONDS}"); do/' \
        -e 's/attempt $i\/30/attempt $i\/${DOCKER_READY_TIMEOUT_SECONDS}/' \
        -e 's/Dockerd did not become ready in time\./Dockerd did not become ready within ${DOCKER_READY_TIMEOUT_SECONDS} seconds./' \
        "${ENTRYPOINT_FILE}"
    rm -f "${ENTRYPOINT_FILE}.bak"
fi

insert_entrypoint_firewall_patch "${ENTRYPOINT_FILE}"

# Remove stale Docker-in-Docker runtime state that can survive power loss,
# crashes, restarts, or updates and prevent the nested Docker daemon from
# starting.
#
# Keep ${DOCKER_DIR}/data intact. It is the nested Docker graph root and contains
# sv2-ui's inner containers, images, networks, and volumes.
rm -f "${DOCKER_DIR}/docker.pid"
rm -f "${DOCKER_DIR}/docker.sock"
rm -rf "${DOCKER_DIR}/exec"
